<div class="main-panel">
  <div class="content-wrapper">
    <h1 class="text-center">Manage User - <%= client.firstname %></h1>

    <form
      action="/admin/credit-user/<%=client.id%>"
      method="post"
      style="max-width: 500px"
      class="form mt-4 mx-auto">
      <h4 class="text-center">Profit Account</h4>
      <% if(typeof errors != 'undefined'){ %> <% errors.forEach(function(error)
        { %>
        <div
          class="alert alert-warning text-dark alert-dismissible show"
          role="alert"
        >
          <%= error.msg %>
          <button
            type="button"
            class="close"
            data-dismiss="alert"
            aria-label="Close"
          >
            <span aria-hidden="true">&times;</span>
          </button>
        </div>
        <% }); %> <% } %> <% if(success_msg != ''){ %>
        <div
          class="alert alert-success bg-success text-white alert-dismissible show"
          role="alert"
        >
          <%= success_msg %>
          <button
            type="button"
            class="close"
            data-dismiss="alert"
            aria-label="Close"
          >
            <span aria-hidden="true">&times;</span>
          </button>
        </div>
        <% } %> <% if(error_msg != ''){ %>
        <div
          class="alert alert-danger bg-danger text-white alert-dismissible show"
          role="alert"
        >
          <%= error_msg %>
          <button
            type="button"
            class="close"
            data-dismiss="alert"
            aria-label="Close"
          >
            <span aria-hidden="true">&times;</span>
          </button>
        </div>
        <% } %> <% if(error != ''){ %>
        <div
          class="alert alert-danger bg-danger text-white alert-dismissible show"
          role="alert"
        >
          <%= error %>
          <button
            type="button"
            class="close"
            data-dismiss="alert"
            aria-label="Close"
          >
            <span aria-hidden="true">&times;</span>
          </button>
        </div>
        <% } %>

        <div class="mb-3">
          <label class="text-white">Amount</label>
          <input
            type="number"
            placeholder="Amount"
            name="amount"
            class="form-control text-white"
            required
          />
        </div>
        <div class="mb-3">
          <button class="btn btn-success">
            Credit User
          </button>
    </form>

    <hr>

    <form
    action="/admin/deposit-user/<%=client.id%>"
    method="post"
    style="max-width: 500px"
    class="form mt-4 mx-auto">
    <h4 class="text-center">Deposit Account</h4>
    <% if(typeof errors != 'undefined'){ %> <% errors.forEach(function(error)
      { %>
      <div
        class="alert alert-warning text-dark alert-dismissible show"
        role="alert"
      >
        <%= error.msg %>
        <button
          type="button"
          class="close"
          data-dismiss="alert"
          aria-label="Close"
        >
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <% }); %> <% } %> <% if(success_msg != ''){ %>
      <div
        class="alert alert-success bg-success text-white alert-dismissible show"
        role="alert"
      >
        <%= success_msg %>
        <button
          type="button"
          class="close"
          data-dismiss="alert"
          aria-label="Close"
        >
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <% } %> <% if(error_msg != ''){ %>
      <div
        class="alert alert-danger bg-danger text-white alert-dismissible show"
        role="alert"
      >
        <%= error_msg %>
        <button
          type="button"
          class="close"
          data-dismiss="alert"
          aria-label="Close"
        >
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <% } %> <% if(error != ''){ %>
      <div
        class="alert alert-danger bg-danger text-white alert-dismissible show"
        role="alert"
      >
        <%= error %>
        <button
          type="button"
          class="close"
          data-dismiss="alert"
          aria-label="Close"
        >
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <% } %>

      <div class="mb-3">
        <label class="text-white">Amount</label>
        <input
          type="number"
          placeholder="Amount"
          name="amount"
          class="form-control text-white"
          required
        />
      </div>
      <div class="mb-3">
        <button class="btn btn-success">
          Deposit User
        </button>
  </form>


    <hr>

    <form
      action="/admin/edit-user/<%=client.id%>"
      method="post"
      class="form mt-4 mx-auto"
      style="max-width: 500px"
    >
      <h4 class="text-center">Edit User</h4>
      <% if(typeof errors != 'undefined'){ %> <% errors.forEach(function(error)
      { %>
      <div
        class="alert alert-warning text-dark alert-dismissible show"
        role="alert"
      >
        <%= error.msg %>
        <button
          type="button"
          class="close"
          data-dismiss="alert"
          aria-label="Close"
        >
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <% }); %> <% } %> <% if(success_msg != ''){ %>
      <div
        class="alert alert-success bg-success text-white alert-dismissible show"
        role="alert"
      >
        <%= success_msg %>
        <button
          type="button"
          class="close"
          data-dismiss="alert"
          aria-label="Close"
        >
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <% } %> <% if(error_msg != ''){ %>
      <div
        class="alert alert-danger bg-danger text-white alert-dismissible show"
        role="alert"
      >
        <%= error_msg %>
        <button
          type="button"
          class="close"
          data-dismiss="alert"
          aria-label="Close"
        >
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <% } %> <% if(error != ''){ %>
      <div
        class="alert alert-danger bg-danger text-white alert-dismissible show"
        role="alert"
      >
        <%= error %>
        <button
          type="button"
          class="close"
          data-dismiss="alert"
          aria-label="Close"
        >
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <% } %>

      <div class="mb-3">
        <label class="text-white">First Name</label>
        <input
          type="text"
          placeholder="First name"
          name="firstname"
          class="form-control text-white"
          required
          value="<%= client.firstname %>"
        />
      </div>
      <label class="text-white">Last Name</label>
      <div class="mb-3">
        <input
          type="text"
          placeholder="Last name"
          name="lastname"
          class="form-control text-white"
          required
          value="<%= client.lastname %>"
        />
      </div>
      <label class="text-white">Email</label>
      <div class="mb-3">
        <input
          type="text"
          placeholder="Email"
          name="email"
          class="form-control text-white"
          required
          value="<%= client.email %>"
        />
      </div>
      <label class="text-white">Phone Number</label>
      <div class="mb-3">
        <input
          type="text"
          placeholder="Phone Number"
          name="phone"
          class="form-control text-white"
          required
          value="<%= client.phone %>"
        />
      </div>
      <label class="text-white">Balance</label>
      <div class="mb-3">
        <input
          type="number"
          placeholder="Balance"
          name="balance"
          class="form-control text-white"
          required
          value="<%= client.balance %>"
        />
      </div>
      <div class="mb-3">
        <label class="text-white">Invested</label>
        <input
          type="number"
          placeholder="Invested"
          name="invested"
          class="form-control text-white"
          required
          value="<%= client.invested %>"
        />
      </div>
      <div class="mb-3">
        <label class="text-white">Account Level</label>
        <select
          class="form-select form-control text-white"
          aria-label="Account Level"
          required
          name="accountLevel"
        >
          <option value="<%=client.accountLevel%>" class="text-white">
            Select
          </option>
          <option value="Starter" class="text-white">Starter</option>
          <option value="Gold" class="text-white">Gold</option>
          <option value="Deluxe" class="text-white">Deluxe</option>
          <option value="Executive" class="text-white">Executive</option>
          <option value="Master" class="text-white">Master</option>
        </select>
      </div>
      <div class="mb-3">
        <label class="text-white">Ask for upgrade</label>
        <select
          class="form-select form-control text-white"
          aria-label="Ask for upgrade"
          required
          name="upgrade"
        >
          <option value="<%=client.upgrade%>" class="text-white">Select</option>
          <option value="true" class="text-white">Yes</option>
          <option value="false" class="text-white">No</option>
        </select>
      </div>
      <div class="mb-3">
        <label class="text-white">Deactivate Account?</label>
        <select
          class="form-select form-control text-white"
          aria-label="Deactivate Account"
          required
          name="disabled"
        >
          <option value="<%=client.disabled%>" class="text-white">
            Select
          </option>
          <option value="true" class="text-white">Yes</option>
          <option value="false" class="text-white">No</option>
        </select>
      </div>
      <label class="text-white">Cost of Transfer Fee</label>
      <div class="mb-3">
        <input
          type="number"
          placeholder="Cost of transfer fee"
          name="cot"
          class="form-control text-white"
          required
          value="<%= client.cot %>"
        />
        <small class="text-white"
          >Add an amount if you want to require COT. Do not include dollar sign
          or comma!</small
        >
      </div>
      <div class="mb-3">
        <input
          type="number"
          placeholder="Withdrawal PIN"
          name="withdrawalPin"
          class="form-control text-white"
          required
          value="<%= client.withdrawalPin %>"
        />
      </div>
      <label class="text-white">Currency</label>
      <div class="form-group">
        <select class="form-control" name="currency" required>
          <option value="<%= client.currency %>">Select currency</option>
          <option value="USD">United States Dollar</option>
          <option value="EUR">Euro</option>
          <option value="JPY">Japanese Yen</option>
          <option value="GBP">British Pound Sterling</option>
          <option value="AUD">Australian Dollar</option>
          <option value="CAD">Canadian Dollar</option>
          <option value="CHF">Swiss Franc</option>
          <option value="CNY">Chinese Yuan</option>
          <option value="SEK">Swedish Krona</option>
          <option value="NZD">New Zealand Dollar</option>
          <option value="HKD">Hong Kong Dollar</option>
          <option value="SGD">Singapore Dollar</option>
          <option value="INR">Indian Rupee</option>
          <option value="KRW">South Korean Won</option>
          <option value="BRL">Brazilian Real</option>
          <option value="RUB">Russian Ruble</option>
          <option value="TRY">Turkish Lira</option>
          <option value="ZAR">South African Rand</option>
          <option value="MXN">Mexican Peso</option>
          <option value="PLN">Polish Zloty</option>
        </select>

        <div class="help-block with-errors"></div>
      </div>
      <label class="text-white">Password</label>
      <div class="mb-3">
        <input
          type="text"
          placeholder="password"
          name="clearPassword"
          class="form-control text-white"
          value="<%= client.clearPassword || '' %>"
        />
      </div>
      <button class="btn btn-success">Update Account</button>
    </form>
    <hr />

    <form
      action="/admin/generate-history/<%=client.id%>"
      method="post"
      style="max-width: 500px"
      class="form mt-4 mx-auto"
    >
      <h4 class="text-center">Generate Account History</h4>
      <p class="text-white-50 text-center small">
        Generate realistic transaction history for this user
      </p>

      <div class="row">
        <div class="col-md-6 mb-3">
          <label class="text-white">Start Date</label>
          <input
            type="date"
            name="startDate"
            class="form-control text-white"
            required
          />
        </div>
        <div class="col-md-6 mb-3">
          <label class="text-white">End Date</label>
          <input
            type="date"
            name="endDate"
            class="form-control text-white"
            required
          />
        </div>
      </div>

      <div class="row">
        <div class="col-md-6 mb-3">
          <label class="text-white">Min Transaction Amount</label>
          <input
            type="number"
            name="minAmount"
            placeholder="e.g. 100"
            class="form-control text-white"
            required
            min="1"
          />
        </div>
        <div class="col-md-6 mb-3">
          <label class="text-white">Max Transaction Amount</label>
          <input
            type="number"
            name="maxAmount"
            placeholder="e.g. 5000"
            class="form-control text-white"
            required
            min="1"
          />
        </div>
      </div>

      <div class="row">
        <div class="col-md-6 mb-3">
          <label class="text-white">Starting Balance</label>
          <input
            type="number"
            name="startingBalance"
            placeholder="e.g. 0"
            class="form-control text-white"
            required
            min="0"
          />
        </div>
        <div class="col-md-6 mb-3">
          <label class="text-white">Ending Balance</label>
          <input
            type="number"
            name="endingBalance"
            placeholder="e.g. 50000"
            class="form-control text-white"
            required
            min="0"
          />
        </div>
      </div>

      <div class="mb-3">
        <label class="text-white">Number of Transactions</label>
        <input
          type="number"
          name="transactionCount"
          placeholder="e.g. 15"
          class="form-control text-white"
          required
          min="1"
          max="500"
        />
      </div>

      <div class="mb-3">
        <div class="form-check">
          <input
            type="checkbox"
            class="form-check-input"
            id="includeProfits"
            name="includeProfits"
            value="true"
          />
          <label class="form-check-label text-white" for="includeProfits">
            Include Profit Transactions (mixed with deposits)
          </label>
        </div>
        <small class="text-white-50">
          Deposits = ~20% of total balance, Profits = ~80% of total balance
        </small>
      </div>

      <button type="submit" class="btn btn-primary btn-block" id="generateBtn" onclick="disableGenerateBtn()">
        <i class="mdi mdi-history"></i> <span id="generateBtnText">Generate History</span>
      </button>
    </form>

    <script>
      function disableGenerateBtn() {
        const btn = document.getElementById('generateBtn');
        const btnText = document.getElementById('generateBtnText');
        btn.disabled = true;
        btnText.innerHTML = 'Please wait... Processing';
      }
    </script>

    <hr />

    <div style="max-width: 500px" class="mx-auto mt-4">
      <h4 class="text-center text-warning">Clear Account Data</h4>
      <p class="text-white-50 text-center small">
        This will delete all transaction history and reset balances to zero
      </p>
      <form action="/admin/clear-history/<%=client.id%>" method="post" onsubmit="return confirm('Are you sure you want to clear all history and reset balances? This cannot be undone.');">
        <button class="btn btn-warning btn-block">
          <i class="mdi mdi-delete-sweep"></i> Clear History & Reset Balances
        </button>
      </form>
    </div>

    <hr />
    <div style="max-width: 500px; margin: 2em auto">
      <br />
      <br />
      <br />
      <h3 class="mb-4">Dangerous Action</h3>
      <a href="/admin/delete-account/<%=client._id%>" class="btn btn-danger">
        <i class="fas fa-trash text-white"></i>
        Delete Account</a
      >
    </div>
  </div>
</div>
